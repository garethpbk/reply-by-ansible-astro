---
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700&family=Rajdhani:wght@400;500;600;700&display=swap" rel="stylesheet" />

		<ClientRouter />
		<title>Reply By Ansible - A Science Fiction & Fantasy Podcast</title>
	</head>
	<body>
		<slot />
		<div id="persistent-player" transition:persist></div>
		<Footer />
		<script src="../scripts/audio-player.ts"></script>
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		height: 100%;
	}

	body {
		font-family: 'Rajdhani', sans-serif;
		background-color: #0a0e17;
		color: #e8edf5;
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	h1, h2, h3, h4, h5, h6 {
		font-family: 'Orbitron', sans-serif;
		font-weight: 600;
		line-height: 1.2;
		margin: 0;
	}

	p {
		margin: 0;
	}

	a {
		color: #00d9ff;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	a:hover {
		color: #33e0ff;
	}

	/* ─── Audio Player ──────────────────────────────────────────────── */

	#persistent-player {
		position: fixed;
		bottom: 0;
		left: 0;
		right: 0;
		z-index: 9999;
		transform: translateY(100%);
		transition: transform 0.3s ease;
		pointer-events: none;
	}
	#persistent-player.active {
		transform: translateY(0);
		pointer-events: auto;
	}

	.player-bar {
		background: rgba(10, 14, 23, 0.95);
		backdrop-filter: blur(12px);
		border-top: 1px solid rgba(0, 217, 255, 0.25);
		padding: 0.5rem 1.25rem;
		display: flex;
		align-items: center;
		gap: 1rem;
		min-height: 64px;
		font-family: 'Rajdhani', sans-serif;
	}

	.player-episode-info {
		display: flex;
		flex-direction: column;
		min-width: 0;
		max-width: 200px;
		flex-shrink: 0;
	}
	.player-ep-number {
		font-size: 0.6875rem;
		color: #00d9ff;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}
	.player-ep-title {
		font-size: 0.8125rem;
		color: #e8edf5;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		font-weight: 500;
	}

	.player-controls {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		flex-shrink: 0;
	}
	.player-controls button {
		background: none;
		border: none;
		color: #e8edf5;
		cursor: pointer;
		padding: 0.375rem;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: background 0.15s, color 0.15s;
		position: relative;
	}
	.player-controls button:hover {
		background: rgba(0, 217, 255, 0.15);
		color: #00d9ff;
	}
	.player-skip-back, .player-skip-forward {
		position: relative;
	}
	.player-skip-back span, .player-skip-forward span {
		position: absolute;
		font-size: 0.5rem;
		font-weight: 700;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		margin-top: 1px;
	}
	.player-play-pause {
		width: 44px;
		height: 44px;
	}

	.player-seek {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex: 1;
		min-width: 0;
	}
	.player-current-time, .player-total-time {
		font-size: 0.75rem;
		color: rgba(232, 237, 245, 0.7);
		font-variant-numeric: tabular-nums;
		min-width: 40px;
		text-align: center;
		flex-shrink: 0;
	}
	.player-seek-bar {
		flex: 1;
		min-width: 0;
	}

	.player-extras {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		flex-shrink: 0;
	}
	.player-speed {
		background: none;
		border: 1px solid rgba(0, 217, 255, 0.3);
		color: #00d9ff;
		cursor: pointer;
		padding: 0.2rem 0.5rem;
		border-radius: 4px;
		font-size: 0.75rem;
		font-family: 'Rajdhani', sans-serif;
		font-weight: 600;
		min-width: 36px;
		text-align: center;
		transition: background 0.15s;
	}
	.player-speed:hover {
		background: rgba(0, 217, 255, 0.15);
	}

	.player-volume-group {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}
	.player-mute {
		background: none;
		border: none;
		color: #e8edf5;
		cursor: pointer;
		padding: 0.25rem;
		display: flex;
		align-items: center;
		border-radius: 4px;
		transition: color 0.15s;
	}
	.player-mute:hover { color: #00d9ff; }
	.player-volume-bar {
		width: 70px;
	}

	.player-close {
		background: none;
		border: none;
		color: rgba(232, 237, 245, 0.5);
		cursor: pointer;
		padding: 0.375rem;
		display: flex;
		align-items: center;
		border-radius: 4px;
		transition: color 0.15s;
	}
	.player-close:hover { color: #e8edf5; }

	/* Range input styling */
	.player-seek-bar, .player-volume-bar {
		-webkit-appearance: none;
		appearance: none;
		height: 4px;
		background: rgba(232, 237, 245, 0.15);
		border-radius: 2px;
		outline: none;
		cursor: pointer;
	}
	.player-seek-bar::-webkit-slider-thumb, .player-volume-bar::-webkit-slider-thumb {
		-webkit-appearance: none;
		appearance: none;
		width: 14px;
		height: 14px;
		border-radius: 50%;
		background: #00d9ff;
		cursor: pointer;
		border: none;
		box-shadow: 0 0 4px rgba(0, 217, 255, 0.4);
	}
	.player-seek-bar::-moz-range-thumb, .player-volume-bar::-moz-range-thumb {
		width: 14px;
		height: 14px;
		border-radius: 50%;
		background: #00d9ff;
		cursor: pointer;
		border: none;
		box-shadow: 0 0 4px rgba(0, 217, 255, 0.4);
	}

	/* Progress bar on episode cards */
	.episode-progress-bar {
		width: 100%;
		height: 3px;
		background: rgba(232, 237, 245, 0.1);
		border-radius: 2px;
		overflow: hidden;
		margin-top: 0.5rem;
	}
	.episode-progress-fill {
		height: 100%;
		background: #00d9ff;
		border-radius: 2px;
		width: 0%;
		transition: width 0.3s ease;
	}

	/* Play button on cards */
	.episode-play-control {
		margin-top: 1rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}
	.play-episode-btn {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		border: 2px solid #00d9ff;
		background: rgba(0, 217, 255, 0.1);
		color: #00d9ff;
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		transition: background 0.2s, transform 0.15s;
	}
	.play-episode-btn:hover {
		background: rgba(0, 217, 255, 0.25);
		transform: scale(1.05);
	}
	.play-episode-btn.is-playing {
		background: rgba(0, 217, 255, 0.3);
		animation: pulse-glow 2s ease-in-out infinite;
	}
	@keyframes pulse-glow {
		0%, 100% { box-shadow: 0 0 0 0 rgba(0, 217, 255, 0.3); }
		50% { box-shadow: 0 0 12px 4px rgba(0, 217, 255, 0.15); }
	}
	.play-episode-btn .icon-pause { display: none; }
	.play-episode-btn.is-playing .icon-play { display: none; }
	.play-episode-btn.is-playing .icon-pause { display: block; }

	.episode-play-right {
		flex: 1;
		min-width: 0;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.episode-play-duration {
		font-size: 0.8125rem;
		color: rgba(232, 237, 245, 0.6);
		font-family: 'Rajdhani', sans-serif;
	}

	/* Continue Listening section */
	.continue-listening {
		display: none;
		padding: 1.5rem 2rem;
		background: rgba(0, 217, 255, 0.05);
		border-bottom: 1px solid rgba(0, 217, 255, 0.15);
	}
	.continue-listening.visible { display: block; }
	.continue-listening-inner {
		max-width: 1280px;
		margin: 0 auto;
		display: flex;
		align-items: center;
		gap: 1rem;
	}
	.continue-listening-label {
		font-family: 'Orbitron', sans-serif;
		font-size: 0.75rem;
		font-weight: 600;
		color: #00d9ff;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		white-space: nowrap;
	}
	.continue-listening-info {
		flex: 1;
		min-width: 0;
	}
	.continue-listening-title {
		font-size: 0.9375rem;
		color: #e8edf5;
		font-weight: 500;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.continue-listening-ep {
		font-size: 0.75rem;
		color: rgba(232, 237, 245, 0.6);
	}
	.continue-listening-btn {
		font-family: 'Orbitron', sans-serif;
		font-size: 0.75rem;
		font-weight: 600;
		color: #0a0e17;
		background: #00d9ff;
		border: none;
		padding: 0.5rem 1.25rem;
		border-radius: 6px;
		cursor: pointer;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		transition: background 0.2s;
		white-space: nowrap;
	}
	.continue-listening-btn:hover {
		background: #00c4e6;
	}

	/* Body padding when player is active */
	body.player-active {
		padding-bottom: 72px;
	}

	/* Mobile responsive */
	@media (max-width: 767px) {
		.player-bar {
			flex-wrap: wrap;
			padding: 0.5rem 0.75rem;
			gap: 0.375rem;
			min-height: auto;
		}
		.player-episode-info {
			order: 1;
			flex: 1;
			max-width: none;
		}
		.player-controls {
			order: 2;
			flex-shrink: 0;
		}
		.player-close {
			order: 3;
		}
		.player-seek {
			order: 4;
			width: 100%;
			flex: none;
		}
		.player-extras {
			order: 5;
			width: 100%;
			justify-content: center;
			flex: none;
		}
		.player-volume-group { display: none; }

		body.player-active {
			padding-bottom: 120px;
		}

		.continue-listening-inner {
			flex-wrap: wrap;
			gap: 0.5rem;
		}
	}
</style>
